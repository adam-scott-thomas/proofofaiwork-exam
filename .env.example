# Frontend env. Copy this file to .env.local and fill in.
# Never put secrets in here — Vite inlines all VITE_* vars at build time.

# Backend API base. Local dev:  http://localhost:8000
# Staging:                       https://staging.proofofaiwork.com
# Production:                    https://proofofaiwork.com
VITE_API_BASE_URL=http://localhost:8000

# WebSocket origin (usually mirrors API base, scheme swapped to wss in prod).
VITE_WS_BASE_URL=ws://localhost:8000

# Origin where the workbench-scoped JWT is minted via iframe handoff.
# v1 default: same as VITE_API_BASE_URL host.
VITE_AUTH_ORIGIN=http://localhost:8000

# Ed25519 public key for offline proof verification (base64, no padding).
# Used by lib/verify.ts on the public proof page + /verify page.
# Pull this from the PoAW backend's WB_PROOF_PUBLIC_KEY env var; safe to
# commit to .env.local since it's the public half of the signing pair.
VITE_PROOF_PUBLIC_KEY=

# Feature flags. Server still enforces these — these only hide UI affordances.
VITE_FEATURE_VERIFIED_ENABLED=false

# Sentry / analytics — empty in local dev.
VITE_SENTRY_DSN=
